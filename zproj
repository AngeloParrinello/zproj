#!/usr/bin/env bash
set -euo pipefail

# ─── Constants ────────────────────────────────────────────────────────────────

readonly SCRIPT_NAME="zproj"
readonly VERSION="5.0.0"
readonly BARE_DIR=".bare"
readonly GIT_POINTER=".git"
readonly MIN_GIT_VERSION="2.5.0"
readonly MIN_TMUX_VERSION="3.0"

# Known coding agents in discovery order (single source of truth)
readonly _KNOWN_AGENTS=(opencode claude codex amp aider goose gemini)

# ─── Colors ───────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[0;33m'
  BLUE=$'\033[0;34m'
  CYAN=$'\033[0;36m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' BLUE='' CYAN='' RESET=''
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

# Return 0 if version $1 >= version $2, using sort -V if available,
# falling back to a pure-bash numeric comparison for simple X.Y.Z versions.
_version_gte() {
  local v1="$1" v2="$2"
  if printf '%s\n%s\n' "$v2" "$v1" | sort -V -C 2>/dev/null; then
    return 0
  fi
  # Fallback: compare major.minor.patch numerically
  local IFS=.
  # shellcheck disable=SC2206  # Intentional word-split on IFS='.'
  local -a a=($v1) b=($v2)
  local i ai bi
  for i in 0 1 2; do
    ai="${a[$i]:-0}"; bi="${b[$i]:-0}"
    if [[ "$ai" -gt "$bi" ]]; then return 0; fi
    if [[ "$ai" -lt "$bi" ]]; then return 1; fi
  done
  return 0  # equal
}

die() {
  echo -e "${RED}error:${RESET} $*" >&2
  exit 1
}
# Non-fatal colored error — for use inside functions that return 1 so callers
# can perform cleanup before exiting (cannot call die directly in those cases).
_err() { echo -e "${RED}error:${RESET} $*" >&2; }
warn() { echo -e "${YELLOW}warn:${RESET} $*" >&2; }
info() { echo -e "${GREEN}✓${RESET} $*"; }
dim()  { echo -e "${DIM}$*${RESET}"; }
step() { echo -e "  $*"; }

# Print the standard "what to do next" hint after any successful init/clone.
# $1 = directory name to cd into
_hint_next_steps() {
  local dir="$1"
  echo -e "  ${DIM}cd ${dir}${RESET}"
  echo -e "  ${DIM}$SCRIPT_NAME${RESET}              ${DIM}# open session${RESET}"
  echo -e "  ${DIM}$SCRIPT_NAME my-feature${RESET}  ${DIM}# create new worktree + window${RESET}"
}

# Switch to or attach a tmux session, respecting ZPROJ_TEST_NO_ATTACH.
# $1 = session name
_tmux_attach_or_switch() {
  local session="$1"
  if [[ -z "${ZPROJ_TEST_NO_ATTACH:-}" ]]; then
    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$session"
    else
      tmux attach -t "$session"
    fi
  fi
}

# Return 0 if the git repo at $1 has uncommitted changes (dirty), 1 if clean.
_git_is_dirty() {
  git -C "$1" status --porcelain 2>/dev/null | grep -q .
}

# Expand the glob <dir>/*, storing all entries in the global array _GLOB_RESULT.
# Handles directory paths containing spaces correctly.
# Saves and restores dotglob/nullglob shopt state.
#
# IMPORTANT: _GLOB_RESULT is a shared singleton — consume it immediately
# before calling any other function that might call _dotglob_expand.
#
# Usage: _dotglob_expand "/path with spaces/subdir"
#        use "${_GLOB_RESULT[@]+"${_GLOB_RESULT[@]}"}"
#
# The directory and wildcard are kept separate so the shell expands the glob
# with the full quoted path — no word-splitting on the directory component.
declare -a _GLOB_RESULT=()
_dotglob_expand() {
  _GLOB_RESULT=()
  local _dir="$1"
  local _dotglob_was _nullglob_was
  shopt -q dotglob  && _dotglob_was=1 || _dotglob_was=0
  shopt -q nullglob && _nullglob_was=1 || _nullglob_was=0
  shopt -s dotglob nullglob
  _GLOB_RESULT=( "$_dir"/* )
  [[ $_dotglob_was  -eq 0 ]] && shopt -u dotglob
  [[ $_nullglob_was -eq 0 ]] && shopt -u nullglob
}


# Return 0 if $2 (absolute path) is a registered worktree of the bare repo at $1.
# Resolves symlinks on both sides to handle /var vs /private/var on macOS.
_git_is_registered_worktree() {
  local bare_dir="$1"
  local target
  target="$(cd "$2" 2>/dev/null && pwd -P)" || target="$2"

  # Inline the loop rather than using a shared callback via variable name ("$cb").
  # When invoked through a variable, the callback doesn't inherit the caller's
  # local scope, so mutations to `found` would be invisible on return.
  # A nested function defined in the same body would work, but this function
  # is simple enough that inlining is clearer.
  local _rwt_path="" _line _canon
  while IFS= read -r _line; do
    if [[ "$_line" == "worktree "* ]]; then
      _rwt_path="${_line#worktree }"
    elif [[ -z "$_line" && -n "$_rwt_path" ]]; then
      _canon="$(cd "$_rwt_path" 2>/dev/null && pwd -P)" || _canon="$_rwt_path"
      [[ "$_canon" == "$target" ]] && return 0
      _rwt_path=""
    fi
  done < <(git -C "$bare_dir" worktree list --porcelain 2>/dev/null)
  # Check last entry
  if [[ -n "$_rwt_path" ]]; then
    _canon="$(cd "$_rwt_path" 2>/dev/null && pwd -P)" || _canon="$_rwt_path"
    [[ "$_canon" == "$target" ]] && return 0
  fi
  return 1
}

# Detect the default remote branch for a git repo at $1.
# Tries: symbolic-ref HEAD on origin → remote main/master → local main/master
# Prints branch name to stdout, or returns 1 if nothing found.
_git_default_branch() {
  local repo_dir="$1"
  local branch

  # 1. Try remote HEAD pointer (set by `git remote set-head origin -a`)
  branch="$(git -C "$repo_dir" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|refs/remotes/origin/||')"
  [[ -n "$branch" ]] && echo "$branch" && return 0

  # 2. Try the bare repo's own HEAD (set by zproj init --main, covers non-main defaults)
  branch="$(git -C "$repo_dir" symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')"
  if [[ -n "$branch" ]] && \
     git -C "$repo_dir" rev-parse --verify "refs/heads/$branch" &>/dev/null; then
    echo "$branch"; return 0
  fi

  # 3. Try remote main then master
  for candidate in main master; do
    if git -C "$repo_dir" rev-parse --verify "refs/remotes/origin/$candidate" &>/dev/null; then
      echo "$candidate"; return 0
    fi
  done

  # 4. If exactly one local branch exists, use it (handles unusual default names)
  local local_branches
  local_branches="$(git -C "$repo_dir" for-each-ref \
    --format='%(refname:short)' refs/heads/ 2>/dev/null)"
  local branch_count
  branch_count="$(echo "$local_branches" | grep -c .)" || branch_count=0
  if [[ "$branch_count" -eq 1 ]] && [[ -n "$local_branches" ]]; then
    echo "$local_branches"; return 0
  fi

  # 5. Try local main then master as last resort
  for candidate in main master; do
    if git -C "$repo_dir" rev-parse --verify "refs/heads/$candidate" &>/dev/null; then
      echo "$candidate"; return 0
    fi
  done

  return 1
}

# ─── Dependency checks ───────────────────────────────────────────────────────

check_git() {
  if ! command -v git &>/dev/null; then
    die "git is not installed."
  fi

  local git_version
  git_version="$(git --version | sed 's/git version //')"
  if ! _version_gte "$git_version" "$MIN_GIT_VERSION"; then
    die "git >= $MIN_GIT_VERSION required for worktree support (found $git_version)."
  fi
}

check_session_deps() {
  check_git

  if ! command -v tmux &>/dev/null; then
    die "tmux is not installed.\n  Install: https://github.com/tmux/tmux/wiki/Installing"
  fi

  local tmux_version
  tmux_version="$(tmux -V | sed 's/tmux //' | sed 's/[^0-9.].*$//')"
  if ! _version_gte "$tmux_version" "$MIN_TMUX_VERSION"; then
    die "tmux >= $MIN_TMUX_VERSION required for named pane support (found $tmux_version).\n  Named panes are used to target the coding agent pane correctly."
  fi
}

# ─── Tool resolution ──────────────────────────────────────────────────────────

# Print "s" if $1 != 1, else print nothing. Usage: "note$(_plural "$count")"
_plural() { [[ "${1:-0}" == "1" ]] && echo "" || echo "s"; }

# Derive a safe tmux session name from a directory name.
# tmux uses '.' as a session:window.pane separator and ':' as a session:window
# separator in its target syntax, so either character in a project directory
# name causes every -t argument to be misparsed.  Replace both with '-'.
# Usage: session_name="$(_tmux_session_name "$dir")"
_tmux_session_name() { tr '.:'  '--' <<< "$1"; }

_resolve_ide() {
  local candidates=()
  [[ -n "${ZPROJ_EDITOR:-}" ]] && candidates+=("$ZPROJ_EDITOR")
  candidates+=(idea)

  local cmd binary
  for cmd in "${candidates[@]}"; do
    binary="${cmd%% *}"
    if command -v "$binary" &>/dev/null; then
      echo "$cmd"
      return 0
    fi
  done

  die "IntelliJ IDEA ('idea') not found in PATH.\n  Install it or set \$ZPROJ_EDITOR to an alternative IDE command."
}

_resolve_ide_source() {
  local binary="$1"
  if [[ -n "${ZPROJ_EDITOR:-}" && "${ZPROJ_EDITOR%% *}" == "$binary" ]]; then
    echo "\$ZPROJ_EDITOR"
  else
    echo "default"
  fi
}

_is_claude_agent() {
  [[ "$1" == "claude" ]]
}

# Resolve the coding agent command to use in pane 1.
# Resolution order: $CODING_AGENT → auto-discover → empty string (graceful no-op)
# Prints the resolved command string to stdout, or empty string if none found.
_resolve_ai() {
  # Explicit override — must exist as a command
  if [[ -n "${CODING_AGENT:-}" ]]; then
    local binary="${CODING_AGENT%% *}"
    if command -v "$binary" &>/dev/null; then
      echo "$CODING_AGENT"
      return 0
    else
      die "\$CODING_AGENT is set to '${CODING_AGENT}' but '${binary}' was not found in PATH."
    fi
  fi

  # Auto-discover from known terminal coding agents
  local agent
  for agent in "${_KNOWN_AGENTS[@]}"; do
    if command -v "$agent" &>/dev/null; then
      echo "$agent"
      return 0
    fi
  done

  # Nothing found — graceful no-op
  warn "No coding agent found in PATH (${_KNOWN_AGENTS[*]})."
  warn "Set \$CODING_AGENT to specify one, or install a coding agent."
  echo ""
  return 0
}

# Print current tool resolution to stdout (used by --env).
cmd_env() {
  local ide ai
  ide="$(_resolve_ide 2>/dev/null)" || ide="${RED}none${RESET}"
  ai="$(_resolve_ai 2>/dev/null)" || ai=""

  local ide_src
  ide_src="$(_resolve_ide_source "${ide%% *}")"

  local ai_display ai_src
  if [[ -z "$ai" ]]; then
    ai_display="${DIM}none${RESET}"
    ai_src="no agent found"
  else
    ai_display="${CYAN}${ai}${RESET}"
    ai_src="${CODING_AGENT:+\$CODING_AGENT}"
    [[ -z "$ai_src" ]] && ai_src="auto-discovered"
  fi

  local layout
  if _is_claude_agent "${ai%% *}"; then
    layout="3 panes: agent | ide | ccm --plan pro"
  else
    layout="3 panes: agent | ide | shell"
  fi

  echo ""
  echo -e "${BOLD}zproj tool resolution:${RESET}"
  echo ""
  echo -e "  ${BOLD}IDE${RESET}     (pane 2): ${CYAN}${ide}${RESET}  ${DIM}[${ide_src}]${RESET}"
  echo -e "  ${BOLD}Agent${RESET}   (pane 1): ${ai_display}  ${DIM}[${ai_src}]${RESET}"
  echo -e "  ${BOLD}Layout${RESET}          : ${DIM}${layout}${RESET}"
  echo ""
  echo -e "  ${DIM}Override: export ZPROJ_EDITOR=<ide-command>${RESET}"
  echo -e "  ${DIM}Override: export CODING_AGENT=<agent>${RESET}"
  echo ""
}

# ─── Directory resolution ────────────────────────────────────────────────────

# Given a user argument (relative name or path), resolve to an absolute path
# and validate the parent contains .bare.
#
# Returns via globals: PROJECT_DIR, PARENT_DIR, WORKTREE_NAME, SESSION_NAME, WINDOW_NAME
resolve_project_dir() {
  local arg="$1"
  local resolved

  # Resolve to absolute path
  if [[ "$arg" = /* ]]; then
    resolved="$arg"
  else
    resolved="$(pwd)/$arg"
  fi

  # Clean up trailing slashes and normalize
  resolved="$(cd "$(dirname "$resolved")" 2>/dev/null && echo "$(pwd)/$(basename "$resolved")")" ||
    die "Parent directory of '$arg' does not exist."

  PROJECT_DIR="$resolved"
  PARENT_DIR="$(dirname "$resolved")"
  WORKTREE_NAME="$(basename "$resolved")"

  # Validate bare repo structure in parent
  if [[ ! -d "$PARENT_DIR/$BARE_DIR" ]]; then
    echo -e "${RED}error:${RESET} '${PARENT_DIR}' is not a bare worktree root." >&2
    echo "" >&2
    echo -e "  Expected structure:" >&2
    echo -e "    ${BOLD}$(basename "$PARENT_DIR")/${RESET}" >&2
    echo -e "      ${BARE_DIR}/       ${DIM}# bare git repository${RESET}" >&2
    echo -e "      .git          ${DIM}# pointer file: \"gitdir: ./${BARE_DIR}\"${RESET}" >&2
    echo -e "      main/         ${DIM}# main worktree${RESET}" >&2
    echo -e "      feature-x/    ${DIM}# additional worktrees${RESET}" >&2
    echo "" >&2
    echo -e "  To set this up, run:" >&2
    echo -e "    ${CYAN}$SCRIPT_NAME init <directory>${RESET}              ${DIM}# new, existing, or git repo${RESET}" >&2
    echo -e "    ${CYAN}$SCRIPT_NAME clone <git-url> [directory]${RESET}   ${DIM}# from remote${RESET}" >&2
    echo "" >&2
    exit 1
  fi

  SESSION_NAME="$(_tmux_session_name "$(basename "$PARENT_DIR")")"
  WINDOW_NAME="$WORKTREE_NAME"
}

# ─── init helpers ─────────────────────────────────────────────────────────────

# Find the first available backup path: <abs_dir>.bak, then .bak1, .bak2, …
# Prints the chosen path to stdout.
_find_backup_name() {
  local abs_dir="$1"
  local candidate="${abs_dir}.bak"
  if [[ ! -e "$candidate" ]]; then
    echo "$candidate"
    return
  fi
  local n=1
  while [[ $n -le 99 ]]; do
    candidate="${abs_dir}.bak${n}"
    if [[ ! -e "$candidate" ]]; then
      echo "$candidate"
      return
    fi
    ((n++))
  done
  die "Could not find a free backup name for '$(basename "$abs_dir")'. Remove existing .bak files and retry."
}

# Run the core bare-repo init steps inside abs_dir (which must already exist).
# Leaves abs_dir with .bare/, .git pointer, and a main worktree directory.
# Works on git >= 2.5.  Does not require global user.name / user.email.
# Returns 0 on success, 1 on any failure (prints a message to stderr).
# IMPORTANT: uses return 1 (not die) so callers can perform rollback cleanup.
_init_bare_structure() {
  local abs_dir="$1"
  local dir="$2"
  local main_branch="$3"

  # Initialize a bare repo
  step "Initializing ${CYAN}${dir}/${BARE_DIR}${RESET}..."
  git init --bare "$abs_dir/$BARE_DIR" 2>&1 | sed 's/^/    /' || {
    _err "git init --bare failed."; return 1; }

  # Write .git pointer
  echo "gitdir: ./$BARE_DIR" >"$abs_dir/$GIT_POINTER" || {
    _err "could not write .git pointer."; return 1; }
  dim "  Created .git pointer"

  # Enable reflogs
  git -C "$abs_dir" config core.logAllRefUpdates true || {
    _err "could not enable reflogs."; return 1; }
  dim "  Enabled reflogs"

  # Set default branch name
  git -C "$abs_dir/$BARE_DIR" symbolic-ref HEAD "refs/heads/$main_branch" || {
    _err "could not set default branch."; return 1; }
  dim "  Set default branch: $main_branch"

  # Bootstrap: create one empty commit so the branch ref exists and
  # `git worktree add` can check it out.  Supply identity inline so this
  # works even when global user.name / user.email are not configured.
  local _tree_hash
  _tree_hash="$(git -C "$abs_dir/$BARE_DIR" hash-object -t tree /dev/null)" || {
    _err "could not create empty tree."; return 1; }
  GIT_DIR="$abs_dir/$BARE_DIR" \
  GIT_AUTHOR_NAME="zproj" GIT_AUTHOR_EMAIL="zproj@localhost" \
  GIT_COMMITTER_NAME="zproj" GIT_COMMITTER_EMAIL="zproj@localhost" \
    git commit-tree "$_tree_hash" -m "Initial commit" \
    | xargs git -C "$abs_dir/$BARE_DIR" update-ref "refs/heads/$main_branch" || {
      _err "could not create initial commit."; return 1; }
  dim "  Created initial commit"

  # Add the worktree (branch now exists, so plain `worktree add` works on all
  # supported git versions).
  (cd "$abs_dir" && git worktree add "$main_branch" "$main_branch" --quiet) || {
    _err "Failed to create '$main_branch' worktree."; return 1; }
  dim "  Created worktree ${main_branch}/"
}

# Case 1: directory exists but contains no .git — plain directory adoption.
_case1_plain_dir() {
  local abs_dir="$1"
  local dir="$2"
  local main_branch="$3"

  echo -e "${BOLD}Converting existing directory to bare worktree structure...${RESET}"
  echo ""
  step "Detected: plain directory (no git repo)"
  echo ""

  # Step 1: find a safe backup name
  local backup
  backup="$(_find_backup_name "$abs_dir")"
  local backup_name
  backup_name="$(basename "$backup")"

  # Step 2: move original dir aside
  step "Moving ${CYAN}${dir}/${RESET} → ${CYAN}${backup_name}/${RESET} (backup)..."
  mv "$abs_dir" "$backup" ||
    die "Could not move '$dir' to backup location '$backup_name'. Check permissions."
  dim "  Backup created at ${backup_name}/"

  # Step 3: fresh init (rollback: rm new dir, restore backup)
  mkdir -p "$abs_dir"
  if ! _init_bare_structure "$abs_dir" "$dir" "$main_branch" 2>&1; then
    rm -rf "$abs_dir"
    mv "$backup" "$abs_dir"
    die "Init failed. Restored original directory."
  fi

  # Step 4: move backup contents into the main worktree — track each item
  # individually so rollback is lossless if the filesystem fails mid-way.
  step "Moving original files into ${CYAN}${dir}/${main_branch}/${RESET}..."
  _dotglob_expand "$backup"
  local moved_items=()
  local move_failed=false
  local item
  for item in "${_GLOB_RESULT[@]+"${_GLOB_RESULT[@]}"}"; do
    if mv "$item" "$abs_dir/$main_branch/"; then
      moved_items+=("$abs_dir/$main_branch/$(basename "$item")")
    else
      move_failed=true
      break
    fi
  done

  if $move_failed; then
    # Move successfully-transferred items back to backup
    for item in "${moved_items[@]+"${moved_items[@]}"}"; do
      mv "$item" "$backup/" 2>/dev/null || true
    done
    rm -rf "$abs_dir"
    mv "$backup" "$abs_dir"
    die "Failed to move files into worktree. Restored original directory."
  fi
  dim "  Files moved into ${dir}/${main_branch}/"

  # Step 5: remove backup (should be empty now)
  rmdir "$backup" 2>/dev/null || warn "Backup directory '${backup_name}' is not empty — remove it manually."

  echo ""
  info "Converted ${BOLD}${dir}${RESET} → bare worktree with ${BOLD}${main_branch}${RESET}"
  echo ""
  echo -e "  ${DIM}Original files are now in ${dir}/${main_branch}/${RESET}"
  _hint_next_steps "$dir"
}

# Reverse the .git→.bare rename and config changes made during Case 2 upgrade.
# Call on failure after step 4 has succeeded.
_rollback_upgrade() {
  local abs_dir="$1"
  echo -e "  ${YELLOW}Rolling back...${RESET}" >&2
  # Remove the .git pointer file we wrote
  rm -f "$abs_dir/$GIT_POINTER"
  # Rename .bare back to .git
  if [[ -d "$abs_dir/$BARE_DIR" ]]; then
    mv "$abs_dir/$BARE_DIR" "$abs_dir/$GIT_POINTER" 2>/dev/null || true
    # Restore core.bare = false (git sets this automatically on normal repos,
    # but let's be explicit to leave the repo exactly as it was)
    git config --file "$abs_dir/$GIT_POINTER/config" core.bare false 2>/dev/null || true
    git config --file "$abs_dir/$GIT_POINTER/config" --unset core.logAllRefUpdates 2>/dev/null || true
  fi
}

# Case 2: directory contains a .git directory — ordinary git repo upgrade.
_case2_upgrade_repo() {
  local abs_dir="$1"
  local dir="$2"
  local main_branch="$3"     # may be empty; we detect from HEAD
  local main_explicit="${4:-false}"  # true only when --main was explicitly passed

  echo -e "${BOLD}Upgrading existing git repository to bare worktree structure...${RESET}"
  echo ""
  step "Detected: ordinary git repository"
  echo ""

  # Pre-flight: verify at least one commit exists
  if ! git -C "$abs_dir" rev-parse HEAD &>/dev/null 2>&1; then
    die "'${dir}' has no commits yet. Make an initial commit, then re-run."
  fi

  # Pre-flight: verify HEAD is not detached
  local detected_branch
  detected_branch="$(git -C "$abs_dir" symbolic-ref --short HEAD 2>/dev/null)" ||
    die "'${dir}' has a detached HEAD. Check out a branch first, then re-run."

  # Warn only when --main was explicitly passed and differs from HEAD.
  # The default value "main" must not trigger a spurious warning.
  if $main_explicit && [[ "$main_branch" != "$detected_branch" ]]; then
    warn "--main '${main_branch}' ignored for existing repo; using HEAD branch '${detected_branch}'"
  fi
  main_branch="$detected_branch"

  step "HEAD branch: ${CYAN}${main_branch}${RESET}"

  # Step 1: detect dirty working tree
  local is_dirty=false
  _git_is_dirty "$abs_dir" && is_dirty=true

  # Step 2: stash if dirty
  if $is_dirty; then
    step "Stashing working tree changes..."
    git -C "$abs_dir" stash push --include-untracked \
      --message "zproj-upgrade: pre-migration stash" --quiet ||
      die "Failed to stash working tree changes. Resolve any issues and retry."
    dim "  Stash saved (will be restored after migration)"
  fi

  # Step 3: rename .git → .bare
  step "Renaming ${CYAN}.git${RESET} → ${CYAN}.bare${RESET}..."
  if ! mv "$abs_dir/$GIT_POINTER" "$abs_dir/$BARE_DIR"; then
    $is_dirty && git -C "$abs_dir" stash pop --quiet 2>/dev/null || true
    die "Could not rename .git to .bare. Check permissions."
  fi
  dim "  Renamed .git → .bare"

  # Steps 4–6: configure the bare repo and write the .git pointer.
  # Wrapped in a function so any failure under set -e causes return 1
  # and we can roll back the rename cleanly.
  _upgrade_configure() {
    git config --file "$abs_dir/$BARE_DIR/config" core.bare true
    git config --file "$abs_dir/$BARE_DIR/config" --unset core.worktree 2>/dev/null || true
    git config --file "$abs_dir/$BARE_DIR/config" core.logAllRefUpdates true
    echo "gitdir: ./$BARE_DIR" >"$abs_dir/$GIT_POINTER"
    local _rc=0
    while IFS= read -r _remote; do
      git -C "$abs_dir" config \
        "remote.${_remote}.fetch" "+refs/heads/*:refs/remotes/${_remote}/*" || _rc=1
      ((remote_count++)) || true
    done < <(git -C "$abs_dir" remote 2>/dev/null)
    return $_rc
  }

  step "Updating bare repo config..."
  local remote_count=0
  if ! _upgrade_configure; then
    rm -f "$abs_dir/$GIT_POINTER"
    mv "$abs_dir/$BARE_DIR" "$abs_dir/$GIT_POINTER" 2>/dev/null || true
    $is_dirty && git -C "$abs_dir" stash pop --quiet 2>/dev/null || true
    die "Post-rename configuration failed. Restored original .git directory."
  fi
  dim "  core.bare = true, core.worktree removed, reflogs enabled"
  dim "  Created .git pointer"
  if [[ $remote_count -gt 0 ]]; then
    dim "  Fixed fetch refspecs for ${remote_count} remote(s)"
  fi

  # Step 7: move working tree files to a temporary holding area
  local tmp_hold="${abs_dir}/.zproj-wt-tmp"
  step "Moving working tree files to temporary location..."
  mkdir -p "$tmp_hold"

  # Track each moved item individually for lossless rollback.
  local moved_to_tmp=()
  local move8_failed=false
  local item name   # declared before loop; bash local is function-scoped
  shopt -s dotglob nullglob
  for item in "$abs_dir"/*; do
    name="$(basename "$item")"
    [[ "$name" == "$BARE_DIR"       ]] && continue
    [[ "$name" == "$GIT_POINTER"    ]] && continue
    [[ "$name" == ".zproj-wt-tmp"  ]] && continue
    if mv "$item" "$tmp_hold/"; then
      moved_to_tmp+=("$tmp_hold/$name")
    else
      move8_failed=true
      break
    fi
  done
  shopt -u dotglob nullglob

  if $move8_failed; then
    # Return already-moved items to abs_dir
    for item in "${moved_to_tmp[@]+"${moved_to_tmp[@]}"}"; do
      mv "$item" "$abs_dir/" 2>/dev/null || true
    done
    rmdir "$tmp_hold" 2>/dev/null || true
    _rollback_upgrade "$abs_dir"
    $is_dirty && git -C "$abs_dir" stash pop --quiet 2>/dev/null || true
    die "Failed to move working tree files. Repository restored."
  fi
  dim "  Files moved to temporary location"

  # Step 8: create the main worktree (no checkout — files go in manually)
  step "Creating worktree ${CYAN}${main_branch}/${RESET}..."
  if ! (cd "$abs_dir" && git worktree add "$main_branch" "$main_branch" \
        --no-checkout --quiet 2>/dev/null); then
    # Restore files from tmp
    _dotglob_expand "$tmp_hold"
    if [[ ${#_GLOB_RESULT[@]} -gt 0 ]]; then
      mv "${_GLOB_RESULT[@]+"${_GLOB_RESULT[@]}"}" "$abs_dir/" 2>/dev/null || true
    fi
    rmdir "$tmp_hold" 2>/dev/null || true
    _rollback_upgrade "$abs_dir"
    $is_dirty && git -C "$abs_dir" stash pop --quiet 2>/dev/null || true
    die "Failed to create '$main_branch' worktree. Repository restored."
  fi
  dim "  Worktree directory ${main_branch}/ created"

  # Step 9: move working tree files into the main worktree — tracked per-item.
  step "Moving files into ${CYAN}${dir}/${main_branch}/${RESET}..."
  _dotglob_expand "$tmp_hold"
  local moved_to_wt=()
  local move10_failed=false
  for item in "${_GLOB_RESULT[@]+"${_GLOB_RESULT[@]}"}"; do
    name="$(basename "$item")"
    if mv "$item" "$abs_dir/$main_branch/"; then
      moved_to_wt+=("$abs_dir/$main_branch/$name")
    else
      move10_failed=true
      break
    fi
  done

  if $move10_failed; then
    # Return already-transferred items back to tmp_hold
    for item in "${moved_to_wt[@]+"${moved_to_wt[@]}"}"; do
      mv "$item" "$tmp_hold/" 2>/dev/null || true
    done
    # Then move everything from tmp back to abs_dir
    _dotglob_expand "$tmp_hold"
    for item in "${_GLOB_RESULT[@]+"${_GLOB_RESULT[@]}"}"; do
      mv "$item" "$abs_dir/" 2>/dev/null || true
    done
    rmdir "$tmp_hold" 2>/dev/null || true
    (cd "$abs_dir" && git worktree remove --force "$main_branch" 2>/dev/null) || rm -rf "$abs_dir/$main_branch"
    _rollback_upgrade "$abs_dir"
    $is_dirty && git -C "$abs_dir" stash pop --quiet 2>/dev/null || true
    die "Failed to move files into worktree. Repository restored."
  fi
  rmdir "$tmp_hold" 2>/dev/null || true
  dim "  Files moved into ${dir}/${main_branch}/"

  # Step 10: repair worktree links
  git -C "$abs_dir/$main_branch" worktree repair 2>/dev/null || true
  dim "  Worktree links repaired"

  # Step 11: sync index with the files we moved in.
  # git worktree add --no-checkout leaves a blank index in the new worktree.
  # Populate it from HEAD (read-tree), then check out all tracked files so
  # the working tree and index agree. This is necessary so that stash pop
  # can apply cleanly on top of a known-good state.
  git -C "$abs_dir/$main_branch" read-tree HEAD 2>/dev/null || true
  git -C "$abs_dir/$main_branch" checkout -- . 2>/dev/null || true

  # Step 12: restore stash (if we stashed in step 2)
  if $is_dirty; then
    step "Restoring stashed working tree changes..."
    if git -C "$abs_dir/$main_branch" stash pop --index --quiet 2>/dev/null; then
      dim "  Working tree changes restored"
    else
      warn "Could not automatically restore stash."
      warn "Run manually: git -C '${dir}/${main_branch}' stash pop"
    fi
  fi

  echo ""
  info "Upgraded ${BOLD}${dir}${RESET} to bare worktree structure"
  echo ""
  echo -e "  ${DIM}History, branches, remotes, tags, and stash preserved${RESET}"
  echo -e "  ${DIM}Working tree is now at ${dir}/${main_branch}/${RESET}"
  _hint_next_steps "$dir"
}

# Dispatcher: called when abs_dir already exists.
_handle_existing_dir() {
  local abs_dir="$1"
  local dir="$2"
  local main_branch="$3"
  local main_explicit="${4:-false}"

  local git_entry="${abs_dir}/${GIT_POINTER}"

  if [[ ! -e "$git_entry" ]]; then
    # No .git at all — plain directory
    _case1_plain_dir "$abs_dir" "$dir" "$main_branch"
    return
  fi

  if [[ -d "$git_entry" ]]; then
    # .git is a directory — ordinary git repo, upgrade it
    _case2_upgrade_repo "$abs_dir" "$dir" "$main_branch" "$main_explicit"
    return
  fi

  if [[ -f "$git_entry" ]]; then
    # .git is a file — check what's inside
    local first_line
    first_line="$(head -n1 "$git_entry" 2>/dev/null)" || true
    if [[ "$first_line" == gitdir:* ]]; then
      die "'${dir}/.git' is a gitdir pointer file — this directory is already managed by git (linked worktree or submodule). Cannot convert it."
    else
      die "'${dir}/.git' is a file with unexpected content. Cannot determine repo state."
    fi
  fi

  if [[ -d "$git_entry" ]]; then
    # .git is a directory — ordinary git repo, upgrade it
    _case2_upgrade_repo "$abs_dir" "$dir" "$main_branch"
    return
  fi

  die "'${dir}/.git' exists but is neither a file nor a directory. Cannot proceed."
}

# ─── Subcommands ─────────────────────────────────────────────────────────────

cmd_init() {
  local dir="" main_branch="main" main_explicit=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_init
      exit 0
      ;;
    --main)
      shift
      [[ $# -eq 0 ]] && die "--main requires a branch name."
      main_branch="$1"
      main_explicit=true
      ;;
    -*) die "Unknown option: $1." ;;
    *)
      [[ -n "$dir" ]] && die "Too many arguments."
      dir="$1"
      ;;
    esac
    shift
  done

  [[ -z "$dir" ]] && die "Usage: $SCRIPT_NAME init <directory> [--main <branch>]"

  check_git

  # Validate branch name before any filesystem mutation
  if ! git check-ref-format --branch "$main_branch" &>/dev/null; then
    die "Invalid branch name: '$main_branch'\n  Branch names cannot contain spaces, start with '-', or contain '..'"
  fi

  # Resolve absolute path (handles '.', relative names, and absolute paths)
  local abs_dir
  if [[ "$dir" == "." ]]; then
    abs_dir="$(pwd)"
    dir="$(basename "$abs_dir")"
  elif [[ "$dir" = /* ]]; then
    abs_dir="$dir"
    dir="$(basename "$abs_dir")"
  else
    abs_dir="$(pwd)/$dir"
  fi

  # If directory already exists, dispatch to the appropriate handler
  if [[ -d "$abs_dir" ]]; then
    _handle_existing_dir "$abs_dir" "$dir" "$main_branch" "$main_explicit"
    return
  fi

  # ── Fresh init (directory does not exist) ──────────────────────────────────
  echo -e "${BOLD}Initializing empty worktree repository...${RESET}"
  echo ""

  mkdir -p "$abs_dir"
  # Clean up the partially created directory if anything below fails
  if ! _init_bare_structure "$abs_dir" "$dir" "$main_branch" 2>&1; then
    rm -rf "$abs_dir"
    die "Init failed. Cleaned up partial state at '$dir'."
  fi

  echo ""
  info "Initialized ${BOLD}${dir}${RESET} with worktree ${BOLD}${main_branch}${RESET}"
  echo ""
  _hint_next_steps "$dir"
}

cmd_clone() {
  local url="" dir="" main_branch="main"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_clone
      exit 0
      ;;
    --main)
      shift
      [[ $# -eq 0 ]] && die "--main requires a branch name."
      main_branch="$1"
      ;;
    -*) die "Unknown option: $1." ;;
    *)
      if [[ -z "$url" ]]; then
        url="$1"
      elif [[ -z "$dir" ]]; then
        dir="$1"
      else
        die "Too many arguments."
      fi
      ;;
    esac
    shift
  done

  [[ -z "$url" ]] && die "Usage: $SCRIPT_NAME clone <git-url> [directory]"

  check_git

  # Validate branch name before any filesystem mutation
  if ! git check-ref-format --branch "$main_branch" &>/dev/null; then
    die "Invalid branch name: '$main_branch'."
  fi

  # Extract directory name from URL if not specified (like git clone)
  if [[ -z "$dir" ]]; then
    dir="$(basename "$url" .git)"
  fi

  local abs_dir
  if [[ "$dir" = /* ]]; then
    abs_dir="$dir"
    dir="$(basename "$abs_dir")"
  else
    abs_dir="$(pwd)/$dir"
  fi

  [[ -d "$abs_dir" ]] && die "'$dir' already exists."

  echo -e "${BOLD}Initializing worktree repository...${RESET}"
  echo ""

  # Create the directory structure, then run all clone steps.
  # On any failure, clean up the partially created directory.
  mkdir -p "$abs_dir"

  # NOTE: Nested function — shares cmd_clone's local scope intentionally.
  # _clone_steps may modify `main_branch` when the remote's default branch
  # differs from the user-supplied value; the updated value is read by the
  # caller after _clone_steps returns.
  _clone_steps() {
    # Bare clone — abort immediately on failure so subsequent steps
    # don't run against a nonexistent .bare/ directory.
    step "Cloning into ${CYAN}${dir}/${BARE_DIR}${RESET}..."
    git clone --bare "$url" "$abs_dir/$BARE_DIR" 2>&1 | sed 's/^/    /' || {
      _err "git clone --bare failed."; return 1; }

    # Write .git pointer
    echo "gitdir: ./$BARE_DIR" >"$abs_dir/$GIT_POINTER" || {
      _err "could not write .git pointer."; return 1; }
    dim "  Created .git pointer"

    # Fix fetch refspec (the classic bare repo gotcha)
    git -C "$abs_dir" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*" || {
      _err "could not fix fetch refspec."; return 1; }
    dim "  Fixed fetch refspec"

    # Enable reflogs
    git -C "$abs_dir" config core.logAllRefUpdates true || {
      _err "could not enable reflogs."; return 1; }
    dim "  Enabled reflogs"

    # Fetch to populate remote refs
    git -C "$abs_dir" fetch --quiet origin || {
      _err "could not fetch from origin."; return 1; }
    dim "  Fetched remote refs"

    # Detect default branch if "main" doesn't exist
    if ! git -C "$abs_dir" rev-parse --verify "refs/remotes/origin/$main_branch" &>/dev/null; then
      local detected
      detected="$(_git_default_branch "$abs_dir")" || true
      if [[ -n "$detected" ]]; then
        main_branch="$detected"
        dim "  Detected default branch: $main_branch"
      else
        warn "Could not detect default branch. Using '$main_branch'."
      fi
    fi

    # Create the main worktree — use return 1 (not die) so the caller
    # can clean up partial state before reporting the error.
    if ! (cd "$abs_dir" && git worktree add "$main_branch" "$main_branch" --quiet 2>/dev/null) && \
       ! (cd "$abs_dir" && git worktree add "$main_branch" "origin/$main_branch" --quiet 2>/dev/null); then
      _err "Failed to create '$main_branch' worktree."
      return 1
    fi

    # Set upstream tracking
    git -C "$abs_dir/$main_branch" branch --set-upstream-to="origin/$main_branch" "$main_branch" --quiet 2>/dev/null || true
  }

  if ! _clone_steps; then
    rm -rf "$abs_dir"
    die "Clone failed. Cleaned up partial state at '$dir'."
  fi

  echo ""
  info "Initialized ${BOLD}${dir}${RESET} with worktree ${BOLD}${main_branch}${RESET}"
  echo ""
  _hint_next_steps "$dir"
}

cmd_create() {
  local from_ref="" dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_create
      exit 0
      ;;
    --from)
      shift
      [[ $# -eq 0 ]] && die "--from requires a ref."
      from_ref="$1"
      ;;
    -*) die "Unknown option: $1." ;;
    *)
      [[ -n "$dir" ]] && die "Too many arguments."
      dir="$1"
      ;;
    esac
    shift
  done

  [[ -z "$dir" ]] && die "Usage: $SCRIPT_NAME create <worktree-dir> [--from <ref>]"

  check_git
  resolve_project_dir "$dir"

  [[ -d "$PROJECT_DIR" ]] && die "Worktree '$WORKTREE_NAME' already exists at $PROJECT_DIR"

  # Validate that the worktree name is a valid branch name
  if ! git check-ref-format --branch "$WORKTREE_NAME" &>/dev/null; then
    die "Invalid worktree/branch name: '$WORKTREE_NAME'."
  fi

  # Default base ref: HEAD of the bare repo (usually origin/main)
  if [[ -z "$from_ref" ]]; then
    from_ref="$(_git_default_branch "$PARENT_DIR")" || true
    [[ -z "$from_ref" ]] && die "Could not determine base ref. Use --from <ref>."
  fi

  # Validate the from-ref exists
  if ! git -C "$PARENT_DIR" rev-parse --verify "${from_ref}^{commit}" &>/dev/null; then
    die "Base ref '$from_ref' does not exist or is not a commit."
  fi

  echo -e "Creating worktree ${BOLD}${WORKTREE_NAME}${RESET} from ${CYAN}${from_ref}${RESET}..."

  (cd "$PARENT_DIR" && git worktree add "$WORKTREE_NAME" -b "$WORKTREE_NAME" "$from_ref" --quiet) ||
    die "Failed to create worktree. Does the branch '$WORKTREE_NAME' already exist?"

  # Set upstream if the base was a remote branch
  if git -C "$PROJECT_DIR" rev-parse --verify "refs/remotes/origin/$from_ref" &>/dev/null; then
    git -C "$PROJECT_DIR" branch --set-upstream-to="origin/$from_ref" "$WORKTREE_NAME" --quiet 2>/dev/null || true
  fi

  info "Created worktree ${BOLD}${WORKTREE_NAME}${RESET} → branch ${CYAN}${WORKTREE_NAME}${RESET}"
}

cmd_delete() {
  local force=false dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_delete
      exit 0
      ;;
    --force | -f) force=true ;;
    -*) die "Unknown option: $1." ;;
    *)
      [[ -n "$dir" ]] && die "Too many arguments."
      dir="$1"
      ;;
    esac
    shift
  done

  [[ -z "$dir" ]] && die "Usage: $SCRIPT_NAME delete <worktree-dir> [--force]"

  check_git
  resolve_project_dir "$dir"

  [[ ! -d "$PROJECT_DIR" ]] && die "Worktree '$WORKTREE_NAME' does not exist."

  # Safety: verify it is actually a registered git worktree, not just any sibling dir
  if ! _git_is_registered_worktree "$PARENT_DIR" "$PROJECT_DIR"; then
    die "'$WORKTREE_NAME' exists but is not a registered git worktree.\n  Run: git -C '$(basename "$PARENT_DIR")' worktree list"
  fi

  # Safety: check for tmux window
  if tmux has-session -t "$SESSION_NAME" 2>/dev/null &&
    tmux list-windows -t "$SESSION_NAME" -F '#{window_name}' 2>/dev/null | grep -qx "$WINDOW_NAME"; then
    if [[ "$force" != true ]]; then
      die "tmux window '${WINDOW_NAME}' in session '${SESSION_NAME}' is still open.\n  Close it first, or use ${CYAN}--force${RESET} to remove everything."
    fi
    echo -e "  Killing tmux window ${BOLD}${SESSION_NAME}:${WINDOW_NAME}${RESET}..."
    tmux kill-window -t "$SESSION_NAME:$WINDOW_NAME" 2>/dev/null || true
  fi

  # Safety: check for uncommitted changes
  if [[ "$force" != true ]] && _git_is_dirty "$PROJECT_DIR"; then
    die "Worktree '$WORKTREE_NAME' has uncommitted changes.\n  Commit or stash them, or use ${CYAN}--force${RESET}."
  fi

  # Capture the branch the worktree is on before we remove it
  local branch_name
  branch_name="$(git -C "$PROJECT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true

  # Remove worktree
  echo -e "  Removing worktree ${BOLD}${WORKTREE_NAME}${RESET}..."
  if [[ "$force" == true ]]; then
    (cd "$PARENT_DIR" && git worktree remove --force "$WORKTREE_NAME" 2>/dev/null) ||
      rm -rf "$PROJECT_DIR"
  else
    (cd "$PARENT_DIR" && git worktree remove "$WORKTREE_NAME")
  fi

  # Prune stale worktree metadata (must happen before branch delete)
  git -C "$PARENT_DIR" worktree prune --quiet 2>/dev/null || true

  # Only delete the branch when it matches the worktree name.
  # This prevents accidentally deleting a shared branch (e.g. 'main') when
  # the worktree directory was named differently from the branch it tracks.
  if [[ -n "$branch_name" && "$branch_name" == "$WORKTREE_NAME" && "$branch_name" != "HEAD" ]]; then
    if git -C "$PARENT_DIR" branch -d "$branch_name" &>/dev/null; then
      dim "  Deleted branch $branch_name"
    elif [[ "$force" == true ]]; then
      git -C "$PARENT_DIR" branch -D "$branch_name" &>/dev/null &&
        dim "  Force-deleted branch $branch_name"
    fi
  fi

  info "Removed ${BOLD}${WORKTREE_NAME}${RESET}"
}

cmd_launch() {
  local dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_launch
      exit 0
      ;;
    -*) die "Unknown option: $1." ;;
    *)
      [[ -n "$dir" ]] && die "Too many arguments."
      dir="$1"
      ;;
    esac
    shift
  done

  [[ -z "$dir" ]] && die "Usage: $SCRIPT_NAME launch <worktree-dir>"

  resolve_project_dir "$dir"
  check_session_deps

  [[ ! -d "$PROJECT_DIR" ]] && die "Worktree '$WORKTREE_NAME' does not exist.\n  Create it with: ${CYAN}$SCRIPT_NAME create $dir${RESET}"

  if ! _git_is_registered_worktree "$PARENT_DIR" "$PROJECT_DIR"; then
    die "'$WORKTREE_NAME' exists but is not a registered git worktree.\n  Create one with: ${CYAN}$SCRIPT_NAME create $WORKTREE_NAME${RESET}\n  List worktrees:  ${CYAN}$SCRIPT_NAME list${RESET}"
  fi

  local ide ai
  ide="$(_resolve_ide)"
  ai="$(_resolve_ai)"

  local ai_binary="${ai%% *}"
  [[ -z "$ai_binary" ]] && ai_binary="shell"

  local quoted_dir
  printf -v quoted_dir '%q' "$PROJECT_DIR"

  local agent_cmd
  if [[ -n "$ai" ]]; then
    agent_cmd="cd $quoted_dir && $ai"
  else
    agent_cmd="cd $quoted_dir"
  fi

  _setup_panes() {
    local _p1 _p2 _p3
    _p1="$(tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '#{pane_id}' | head -1)"
    tmux send-keys   -t "$_p1" "$agent_cmd" Enter
    tmux select-pane -t "$_p1" -T "$ai_binary"

    _p2="$(tmux split-window -t "$SESSION_NAME:$WINDOW_NAME" -h \
             -c "$PROJECT_DIR" -P -F '#{pane_id}')"
    tmux send-keys   -t "$_p2" "cd $quoted_dir && $ide ." Enter
    tmux select-pane -t "$_p2" -T "${ide%% *}"

    _p3="$(tmux split-window -t "$_p2" -v -c "$PROJECT_DIR" -P -F '#{pane_id}')"
    if _is_claude_agent "$ai_binary"; then
      tmux send-keys   -t "$_p3" "ccm --plan pro" Enter
      tmux select-pane -t "$_p3" -T "ccm"
    else
      tmux select-pane -t "$_p3" -T "shell"
    fi

    tmux select-pane -t "$_p1"
  }

  if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then

    if tmux list-windows -t "$SESSION_NAME" -F '#{window_name}' 2>/dev/null | grep -qx "$WINDOW_NAME"; then
      info "Switching to ${BOLD}${SESSION_NAME}:${WINDOW_NAME}${RESET}"
    else
      tmux new-window -t "$SESSION_NAME:" -n "$WINDOW_NAME" -c "$PROJECT_DIR"
      _setup_panes
      info "Created window ${BOLD}${SESSION_NAME}:${WINDOW_NAME}${RESET}"
    fi

  else
    tmux new-session -d -s "$SESSION_NAME" -n "$WINDOW_NAME" -c "$PROJECT_DIR" -x 220 -y 50
    _setup_panes
    info "Started session ${BOLD}${SESSION_NAME}${RESET} with window ${BOLD}${WINDOW_NAME}${RESET}"
  fi

  tmux select-window -t "$SESSION_NAME:$WINDOW_NAME"
  _tmux_attach_or_switch "$SESSION_NAME"
}

cmd_list() {
  local target_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage_list
      exit 0
      ;;
    -*) die "Unknown option: $1." ;;
    *)
      [[ -n "$target_dir" ]] && die "Too many arguments."
      target_dir="$1"
      ;;
    esac
    shift
  done

  check_git

  # Find the bare repo root
  local root
  if [[ -n "$target_dir" ]]; then
    root="$(cd "$target_dir" 2>/dev/null && pwd)" ||
      die "Directory '$target_dir' does not exist."
  else
    root="$(pwd)"
  fi

  # Walk up to find .bare if we're inside a worktree
  while [[ "$root" != "/" ]]; do
    [[ -d "$root/$BARE_DIR" ]] && break
    if [[ -d "$(dirname "$root")/$BARE_DIR" ]]; then
      root="$(dirname "$root")"
      break
    fi
    root="$(dirname "$root")"
  done

  [[ ! -d "$root/$BARE_DIR" ]] && die "No bare repo found. Run from a worktree root or specify a path."

  local root_name
  root_name="$(_tmux_session_name "$(basename "$root")")"

  # Get list of tmux windows for this session (if session exists)
  local -a tmux_windows=()
  if tmux has-session -t "$root_name" 2>/dev/null; then
    while IFS= read -r win; do
      tmux_windows+=("$win")
    done < <(tmux list-windows -t "$root_name" -F '#{window_name}:#{window_active}' 2>/dev/null)
  fi

  echo ""
  echo -e "  ${BOLD}${root_name}${RESET} worktrees:"
  echo ""

  # Column widths
  local max_name=0 max_branch=0

  # Gather data using --porcelain (handles spaces in paths/branch names).
  # _list_process_entry is a nested function (defined in this function body)
  # so it can freely write to the local arrays wt_names, wt_branches, etc.
  # We cannot factor the stanza parser into a shared helper with a variable-
  # name callback, because that breaks local-scope writes. The per-entry logic
  # here also differs from cmd_open and _git_is_registered_worktree, so no
  # single shared parser would serve all three without adding complexity.
  local -a wt_names=() wt_branches=() wt_dirty=() wt_window=()
  local _wt_path="" _wt_branch=""

  _list_process_entry() {
    # Called when a complete porcelain stanza has been accumulated
    [[ "$_wt_branch" == "(bare)" ]] && return
    local _name _dirty _window_status
    _name="$(basename "$_wt_path")"
    _dirty="clean"; _git_is_dirty "$_wt_path" && _dirty="dirty"
    _window_status="none"
    local _win_entry
    for _win_entry in "${tmux_windows[@]+"${tmux_windows[@]}"}"; do
      local _wn="${_win_entry%%:*}" _wa="${_win_entry##*:}"
      if [[ "$_wn" == "$_name" ]]; then
        [[ "$_wa" == "1" ]] && _window_status="active" || _window_status="open"
        break
      fi
    done
    wt_names+=("$_name")
    wt_branches+=("$_wt_branch")
    wt_dirty+=("$_dirty")
    wt_window+=("$_window_status")
    # Use || true to prevent (( )) from exiting 1 (false) and triggering set -e
    # when the new value is not larger than the current max.
    (( ${#_name} > max_name )) && max_name=${#_name} || true
    (( ${#_wt_branch} > max_branch )) && max_branch=${#_wt_branch} || true
  }

  while IFS= read -r _line; do
    if   [[ "$_line" == "worktree "* ]]; then _wt_path="${_line#worktree }"
    elif [[ "$_line" == "HEAD "* ]];     then : # HEAD sha not used
    elif [[ "$_line" == "branch "* ]];   then
      _wt_branch="${_line#branch }"; _wt_branch="${_wt_branch#refs/heads/}"
    elif [[ "$_line" == "bare" ]];       then _wt_branch="(bare)"
    elif [[ "$_line" == "detached" ]];   then _wt_branch=""
    elif [[ -z "$_line" && -n "$_wt_path" ]]; then
      _list_process_entry
      _wt_path="" _wt_branch=""
    fi
  done < <(git -C "$root" worktree list --porcelain 2>/dev/null)
  [[ -n "$_wt_path" ]] && _list_process_entry

  if [[ ${#wt_names[@]} -eq 0 ]]; then
    echo -e "    ${DIM}(no worktrees)${RESET}"
    echo ""
    return
  fi

  # Minimum column widths
  ((max_name < 12)) && max_name=12 || true
  ((max_branch < 8)) && max_branch=8 || true

  # Declare loop variables before the loop — bash local is function-scoped,
  # not block-scoped; declaring inside a loop is semantically misleading.
  local name branch dirty window
  local dirty_str dirty_pad
  local window_str window_pad
  for i in "${!wt_names[@]}"; do
    name="${wt_names[$i]}"
    branch="${wt_branches[$i]}"
    dirty="${wt_dirty[$i]}"
    window="${wt_window[$i]}"

    # Format dirty status. Pad values are hard-coded constants (avoids locale-
    # dependent ${#var} byte-counting of multi-byte Unicode characters like ✓).
    # All strings in each group are the same visible width, so pad is always 0.
    dirty_pad=0
    if [[ "$dirty" == "clean" ]]; then
      dirty_str="${GREEN}✓ clean${RESET}"   # 7 visible chars
    else
      dirty_str="${RED}✗ dirty${RESET}"     # 7 visible chars
    fi

    # Window status strings have different lengths; pad to width of longest (11).
    case "$window" in
    active) window_str="${GREEN}● active${RESET}";    window_pad=3 ;;  # 11-8
    open)   window_str="${YELLOW}○ open${RESET}";     window_pad=5 ;;  # 11-6
    none)   window_str="${DIM}- no window${RESET}";   window_pad=0 ;;  # 11-11
    esac

    printf "    ${BOLD}%-${max_name}s${RESET}  ${CYAN}%-${max_branch}s${RESET}  %s%${dirty_pad}s  %s%${window_pad}s\n" \
      "$name" "$branch" "$dirty_str" "" "$window_str" ""
  done

  echo ""
}

# ─── Open session (no-arg) ────────────────────────────────────────────────────

cmd_open() {
  local root
  root="$(pwd)"

  if [[ ! -d "$root/$BARE_DIR" ]]; then
    echo -e "${RED}error:${RESET} Not in a bare worktree root." >&2
    echo "" >&2
    echo -e "  To open a project session, run ${CYAN}$SCRIPT_NAME${RESET} from the project root:" >&2
    echo -e "    ${DIM}cd ~/projects/zio-blocks${RESET}" >&2
    echo -e "    ${DIM}$SCRIPT_NAME${RESET}" >&2
    echo "" >&2
    echo -e "  Or specify a worktree to open directly:" >&2
    echo -e "    ${DIM}$SCRIPT_NAME feature-auth${RESET}" >&2
    echo -e "    ${DIM}$SCRIPT_NAME ~/projects/zio-blocks/feature-auth${RESET}" >&2
    echo "" >&2
    exit 1
  fi

  check_session_deps

  local session_name
  session_name="$(_tmux_session_name "$(basename "$root")")"

  # Session already exists — just attach/switch
  if tmux has-session -t "$session_name" 2>/dev/null; then
    info "Attaching to session ${BOLD}${session_name}${RESET}"
    _tmux_attach_or_switch "$session_name"
    return
  fi

  # Find the first worktree to use as the initial window (prefer main/master).
  # Inlined — a callback via variable name cannot write to `first_wt` here.
  local first_wt=""
  local _op_path="" _op_branch=""
  while IFS= read -r _line; do
    if   [[ "$_line" == "worktree "* ]]; then _op_path="${_line#worktree }"
    elif [[ "$_line" == "HEAD "* ]];     then : # HEAD sha not used
    elif [[ "$_line" == "branch "* ]];   then
      _op_branch="${_line#branch }"; _op_branch="${_op_branch#refs/heads/}"
    elif [[ "$_line" == "bare" ]];       then _op_branch="(bare)"
    elif [[ -z "$_line" && -n "$_op_path" ]]; then
      if [[ "$_op_branch" != "(bare)" ]]; then
        local _op_name; _op_name="$(basename "$_op_path")"
        if [[ "$_op_name" == "main" || "$_op_name" == "master" ]]; then
          first_wt="$_op_name"
        fi
        [[ -z "$first_wt" ]] && first_wt="$_op_name"
      fi
      _op_path="" _op_branch=""
    fi
  done < <(git -C "$root" worktree list --porcelain 2>/dev/null)
  if [[ -n "$_op_path" && "$_op_branch" != "(bare)" ]]; then
    local _op_name; _op_name="$(basename "$_op_path")"
    [[ "$_op_name" == "main" || "$_op_name" == "master" ]] && first_wt="$_op_name"
    [[ -z "$first_wt" ]] && first_wt="$_op_name"
  fi

  if [[ -z "$first_wt" ]]; then
    die "No worktrees found. Create one first:\n  ${CYAN}$SCRIPT_NAME main${RESET}"
  fi

  cmd_launch "$first_wt"
}

# ─── Default action (upsert + launch) ────────────────────────────────────────

cmd_default() {
  local dir="$1"

  resolve_project_dir "$dir"
  check_session_deps

  # Upsert: create if it doesn't exist; error if it exists but isn't a worktree
  if [[ ! -d "$PROJECT_DIR" ]]; then
    cmd_create "$dir"
  elif ! _git_is_registered_worktree "$PARENT_DIR" "$PROJECT_DIR"; then
    die "'$WORKTREE_NAME' exists but is not a registered git worktree.\n  Create one with: ${CYAN}$SCRIPT_NAME create $WORKTREE_NAME${RESET}"
  fi

  # Launch
  cmd_launch "$dir"
}

